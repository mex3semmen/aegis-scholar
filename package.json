{
  "name": "aegis-scholar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:browser-smoke": "playwright test tests/browser-smoke.spec.ts",
    "test:backend": "cargo test --manifest-path ./src-tauri/Cargo.toml",
    "verify:fast": "powershell -ExecutionPolicy Bypass -File ./scripts/verify.ps1 -Fast",
    "verify:backend": "powershell -ExecutionPolicy Bypass -File ./scripts/verify.ps1 -BackendOnly",
    "verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify.ps1",
    "test": "npm run test:browser-smoke && npm run test:backend"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.0"
  }
}
