{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEGIS Answer Draft",
  "type": "object",
  "required": ["answer_draft_id", "evidence_pack_id", "source_id", "version_id", "query", "created_at", "draft_mode", "claim_count", "unsupported_count", "claims", "warnings"],
  "properties": {
    "answer_draft_id": { "type": "string", "pattern": "^adr_[a-f0-9]+$" },
    "evidence_pack_id": { "type": "string", "pattern": "^evp_[a-f0-9]+$" },
    "source_id": { "type": "string", "pattern": "^src_[a-zA-Z0-9_-]+$" },
    "version_id": { "type": "string", "pattern": "^srcv_[a-zA-Z0-9_-]+$" },
    "query": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "draft_mode": { "type": "string", "enum": ["evidence_only"] },
    "claim_count": { "type": "integer", "minimum": 0 },
    "unsupported_count": { "type": "integer", "minimum": 0 },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "status", "text", "evidence_ids", "chunk_ids", "locators", "confidence"],
        "properties": {
          "claim_id": { "type": "string", "pattern": "^dcl_[a-f0-9]+$" },
          "status": { "type": "string", "enum": ["supported", "needs_evidence", "unsupported"] },
          "text": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "chunk_ids": { "type": "array", "items": { "type": "string" } },
          "locators": { "type": "array", "items": { "$ref": "./citation-locator.schema.json" } },
          "confidence": { "type": "string", "enum": ["mechanical", "missing_evidence"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
