{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEGIS Evidence Pack",
  "type": "object",
  "required": ["evidence_pack_id", "source_id", "version_id", "query", "created_at", "retrieval_index_version", "result_count", "item_count", "evidence_pack_version", "items"],
  "properties": {
    "evidence_pack_id": { "type": "string", "pattern": "^evp_[a-f0-9]+$" },
    "source_id": { "type": "string", "pattern": "^src_[a-zA-Z0-9_-]+$" },
    "version_id": { "type": "string", "pattern": "^srcv_[a-zA-Z0-9_-]+$" },
    "query": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "retrieval_index_version": { "type": "string" },
    "result_count": { "type": "integer", "minimum": 0 },
    "item_count": { "type": "integer", "minimum": 0 },
    "evidence_pack_version": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_item_id", "chunk_id", "source_id", "version_id", "locator", "text_hash", "score", "matched_terms", "preview"],
        "properties": {
          "evidence_item_id": { "type": "string", "pattern": "^evi_[a-f0-9]+$" },
          "chunk_id": { "type": "string" },
          "source_id": { "type": "string" },
          "version_id": { "type": "string" },
          "locator": { "$ref": "citation-locator.schema.json" },
          "text_hash": { "type": "string", "pattern": "^sha256:.+" },
          "score": { "type": "number" },
          "matched_terms": { "type": "array", "items": { "type": "string" } },
          "preview": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
