{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEGIS Chunk",
  "type": "object",
  "required": [
    "chunk_id",
    "source_id",
    "version_id",
    "locator",
    "text",
    "content_hash"
  ],
  "properties": {
    "chunk_id": { "type": "string", "pattern": "^chk_[a-zA-Z0-9_-]+$" },
    "source_id": { "type": "string", "pattern": "^src_[a-zA-Z0-9_-]+$" },
    "version_id": { "type": "string", "pattern": "^srcv_[a-zA-Z0-9_-]+$" },
    "locator": { "$ref": "./citation-locator.schema.json" },
    "text": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "pattern": "^sha256:.+" },
    "discipline": { "type": "string" },
    "subdiscipline": { "type": "string" },
    "method_tags": { "type": "array", "items": { "type": "string" } },
    "topic_tags": { "type": "array", "items": { "type": "string" } },
    "extraction_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
