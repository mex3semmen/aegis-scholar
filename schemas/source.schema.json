{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEGIS Source",
  "type": "object",
  "required": [
    "source_id",
    "version_id",
    "title",
    "source_type",
    "discipline",
    "language",
    "content_hash",
    "ingestion_status",
    "created_at"
  ],
  "properties": {
    "source_id": { "type": "string", "pattern": "^src_[a-zA-Z0-9_-]+$" },
    "version_id": { "type": "string", "pattern": "^srcv_[a-zA-Z0-9_-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "source_type": {
      "type": "string",
      "enum": ["pdf", "lecture_slides", "paper", "textbook", "markdown_note", "web_snapshot", "dataset_note"]
    },
    "discipline": { "type": "string" },
    "subdiscipline": { "type": "string" },
    "language": { "type": "string" },
    "content_hash": { "type": "string", "pattern": "^sha256:.+" },
    "path": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "ingestion_status": {
      "type": "string",
      "enum": ["registered", "extraction_pending", "extracted", "chunked", "indexed", "answer_drafted", "grounded_answer_ready", "evidence_ready", "failed", "removed"]
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "reliability_notes": { "type": "string" }
  },
  "additionalProperties": false
}
